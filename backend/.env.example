# Copy to .env and adjust as needed. All values below are the defaults.

# SQLAlchemy database URL (SQLite file in the backend/ dir by default)
DATABASE_URL=sqlite:///./strand.db

# Public ESMFold structure-prediction endpoint the backend proxies to
ESMFOLD_URL=https://api.esmatlas.com/foldSequence/v1/pdb/

# Allowed CORS origins (JSON array — parsed by pydantic-settings)
CORS_ORIGINS=["http://localhost:5173"]
